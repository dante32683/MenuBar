<Window
    x:Class="MenuBar.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="MenuBar">

    <Grid x:Name="RootGrid" Background="Transparent">
        <Grid.ContextFlyout>
            <MenuFlyout>
                <MenuFlyoutItem Text="Open settings" Click="OpenSettingsFile_Click" />
                <MenuFlyoutItem Text="Reload settings" Click="ReloadSettings_Click" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="Restart bar" Click="RestartBar_Click" />
                <MenuFlyoutItem Text="Stop bar" Click="StopBar_Click" />
            </MenuFlyout>
        </Grid.ContextFlyout>

        <Border x:Name="BackgroundBorder" Background="#B01C222A">
            <Grid x:Name="MainContentGrid" Padding="12,0" VerticalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="0" VerticalAlignment="Stretch">
                    <Border x:Name="LogoHost"
                            Visibility="{x:Bind ViewModel.LogoVisibility, Mode=OneWay}"
                            Background="Transparent"
                            CornerRadius="6"
                            Padding="8,0"
                            VerticalAlignment="Stretch"
                            PointerEntered="Host_PointerEntered"
                            PointerExited="Host_PointerExited"
                            PointerPressed="Host_PointerPressed"
                            PointerReleased="Host_PointerReleased"
                            Tapped="LogoHost_Tapped">
                        <ToolTipService.ToolTip>
                            <ToolTip Content="{x:Bind ViewModel.LogoTooltip, Mode=OneWay}" />
                        </ToolTipService.ToolTip>
                        <FlyoutBase.AttachedFlyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="Settings" Click="OpenWindowsSettings_Click" />
                                <MenuFlyoutSeparator />
                                <MenuFlyoutItem Text="Sleep" Click="SleepSystem_Click" />
                                <MenuFlyoutItem Text="Restart" Click="RestartSystem_Click" />
                                <MenuFlyoutSeparator />
                                <MenuFlyoutItem Text="Shut down" Click="ShutdownSystem_Click" />
                            </MenuFlyout>
                        </FlyoutBase.AttachedFlyout>
                        <Grid Width="{x:Bind ViewModel.IconFontSize, Mode=OneWay}" 
                              Height="{x:Bind ViewModel.IconFontSize, Mode=OneWay}" 
                              VerticalAlignment="Center">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Rectangle Fill="White" Grid.Row="0" Grid.Column="0" Margin="0,0,1,1" />
                            <Rectangle Fill="White" Grid.Row="0" Grid.Column="1" Margin="1,0,0,1" />
                            <Rectangle Fill="White" Grid.Row="1" Grid.Column="0" Margin="0,1,1,0" />
                            <Rectangle Fill="White" Grid.Row="1" Grid.Column="1" Margin="1,1,0,0" />
                        </Grid>
                    </Border>

                    <TextBlock Text="{x:Bind ViewModel.ActiveWindowTitle, Mode=OneWay}"
                               Visibility="{x:Bind ViewModel.TitleVisibility, Mode=OneWay}"
                               Foreground="White"
                               FontSize="{x:Bind ViewModel.TextFontSize, Mode=OneWay}"
                               MaxWidth="340"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0">
                        <ToolTipService.ToolTip>
                            <ToolTip Content="{x:Bind ViewModel.ActiveWindowTitleTooltip, Mode=OneWay}" />
                        </ToolTipService.ToolTip>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="2" VerticalAlignment="Stretch">
                    <Border x:Name="MediaHost"
                            Visibility="{x:Bind ViewModel.MediaVisibility, Mode=OneWay}"
                            Background="Transparent"
                            CornerRadius="6"
                            Padding="8,0"
                            VerticalAlignment="Stretch"
                            PointerEntered="Host_PointerEntered"
                            PointerExited="Host_PointerExited"
                            PointerPressed="Host_PointerPressed"
                            PointerReleased="Host_PointerReleased"
                            Tapped="MediaHost_Tapped">
                        <ToolTipService.ToolTip>
                            <ToolTip Content="{x:Bind ViewModel.MediaTooltip, Mode=OneWay}" />
                        </ToolTipService.ToolTip>
                        <FlyoutBase.AttachedFlyout>
                            <Flyout Placement="Bottom" ShouldConstrainToRootBounds="False">
                                <Flyout.FlyoutPresenterStyle>
                                    <Style TargetType="FlyoutPresenter">
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="MinWidth" Value="300" />
                                    </Style>
                                </Flyout.FlyoutPresenterStyle>
                                <Grid Background="{ThemeResource LayerFillColorDefaultBrush}"
                                      CornerRadius="8"
                                      Padding="16"
                                      MinWidth="300">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <StackPanel Orientation="Horizontal" Spacing="16">
                                        <Border Width="80" Height="80" CornerRadius="4" Background="{ThemeResource ControlAltFillColorQuarternaryBrush}">
                                            <Image Source="{x:Bind ViewModel.MediaAlbumCover, Mode=OneWay}" Stretch="UniformToFill" />
                                        </Border>
                                        <StackPanel VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Text="{x:Bind ViewModel.MediaTitle, Mode=OneWay}" 
                                                       FontWeight="SemiBold" 
                                                       FontSize="16" 
                                                       TextTrimming="CharacterEllipsis" 
                                                       MaxWidth="180" />
                                            <TextBlock Text="{x:Bind ViewModel.MediaArtist, Mode=OneWay}" 
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                                       FontSize="14" 
                                                       TextTrimming="CharacterEllipsis" 
                                                       MaxWidth="180" />
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" 
                                                Orientation="Horizontal" 
                                                HorizontalAlignment="Center" 
                                                Spacing="24" 
                                                Margin="0,16,0,0">
                                        <Button Click="MediaPrevious_Click" 
                                                Background="Transparent" 
                                                BorderThickness="0" 
                                                Padding="8">
                                            <SymbolIcon Symbol="Back" />
                                        </Button>
                                        <Button Click="MediaPlayPause_Click" 
                                                Background="{ThemeResource AccentFillColorDefaultBrush}" 
                                                Foreground="White"
                                                Width="48" Height="48" 
                                                CornerRadius="24" 
                                                Padding="0">
                                            <SymbolIcon Symbol="{x:Bind ViewModel.MediaPlayPauseSymbol, Mode=OneWay}" />
                                        </Button>
                                        <Button Click="MediaNext_Click" 
                                                Background="Transparent" 
                                                BorderThickness="0" 
                                                Padding="8">
                                            <SymbolIcon Symbol="Forward" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Flyout>
                        </FlyoutBase.AttachedFlyout>
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <Ellipse Width="6" Height="6" Fill="{x:Bind ViewModel.MediaIndicatorBrush, Mode=OneWay}" />
                            <TextBlock Text="{x:Bind ViewModel.MediaText, Mode=OneWay}"
                                       FontSize="{x:Bind ViewModel.TextFontSize, Mode=OneWay}"
                                       MaxWidth="310"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="White"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <Border x:Name="NetworkHost"
                            Visibility="{x:Bind ViewModel.NetworkVisibility, Mode=OneWay}"
                            Background="Transparent"
                            CornerRadius="6"
                            Padding="8,0"
                            VerticalAlignment="Stretch"
                            PointerEntered="Host_PointerEntered"
                            PointerExited="Host_PointerExited"
                            PointerPressed="Host_PointerPressed"
                            PointerReleased="Host_PointerReleased"
                            Tapped="NetworkHost_Tapped">
                        <ToolTipService.ToolTip>
                            <ToolTip Content="{x:Bind ViewModel.NetworkTooltip, Mode=OneWay}" />
                        </ToolTipService.ToolTip>
                        <FlyoutBase.AttachedFlyout>
                            <MenuFlyout Placement="Bottom">
                                <MenuFlyoutItem x:Name="NetworkMenuPrimaryItem" Text="Not connected" />
                                <MenuFlyoutItem x:Name="NetworkMenuSecondaryItem" Text="" Visibility="Collapsed" />
                                <MenuFlyoutItem x:Name="NetworkMenuDownItem" Text="" Visibility="Collapsed" />
                                <MenuFlyoutItem x:Name="NetworkMenuUpItem" Text="" Visibility="Collapsed" />
                            </MenuFlyout>
                        </FlyoutBase.AttachedFlyout>
                        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind ViewModel.NetworkIcon, Mode=OneWay}" 
                                       FontFamily="Segoe Fluent Icons" 
                                       FontSize="{x:Bind ViewModel.IconFontSize, Mode=OneWay}" 
                                       Foreground="White" 
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <Border x:Name="BatteryHost"
                            Visibility="{x:Bind ViewModel.BatteryVisibility, Mode=OneWay}"
                            Background="Transparent"
                            CornerRadius="6"
                            Padding="8,0"
                            VerticalAlignment="Stretch"
                            PointerEntered="Host_PointerEntered"
                            PointerExited="Host_PointerExited"
                            PointerPressed="Host_PointerPressed"
                            PointerReleased="Host_PointerReleased"
                            Tapped="BatteryHost_Tapped">
                        <ToolTipService.ToolTip>
                            <ToolTip Content="{x:Bind ViewModel.BatteryTooltip, Mode=OneWay}" />
                        </ToolTipService.ToolTip>
                        <FlyoutBase.AttachedFlyout>
                            <MenuFlyout Placement="Bottom">
                                <MenuFlyoutItem x:Name="BatteryMenuPrimaryItem" Text="AC power — no battery detected" />
                                <MenuFlyoutItem x:Name="BatteryMenuSecondaryItem" Text="" Visibility="Collapsed" />
                                <MenuFlyoutItem x:Name="BatteryMenuTimeItem" Text="" Visibility="Collapsed" />
                            </MenuFlyout>
                        </FlyoutBase.AttachedFlyout>
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <Grid Width="22" VerticalAlignment="Center">
                                <TextBlock x:Name="BatteryFillGlyphText"
                                           Text="{x:Bind ViewModel.BatteryIcon, Mode=OneWay}"
                                           FontFamily="Segoe Fluent Icons"
                                           FontSize="{x:Bind ViewModel.IconFontSize, Mode=OneWay}"
                                           Foreground="White"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center" />
                                <TextBlock x:Name="BatteryOutlineGlyphText"
                                           Text="&#xEBA0;"
                                           FontFamily="Segoe Fluent Icons"
                                           FontSize="{x:Bind ViewModel.IconFontSize, Mode=OneWay}"
                                           Foreground="White"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center" />
                                <Path x:Name="BatteryBoltPath"
                                      Visibility="Collapsed"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Fill="White"
                                      Data="M 8,0 L 4.8,4.8 H 7.1 L 5.8,10 L 10,4.4 H 7.7 Z"
                                      Stretch="Uniform"
                                      Width="10"
                                      Height="12"
                                      Margin="0,-4,0,0" />
                            </Grid>
                            <TextBlock Text="{x:Bind ViewModel.BatteryText, Mode=OneWay}" 
                                       FontSize="{x:Bind ViewModel.TextFontSize, Mode=OneWay}" 
                                       Foreground="White" 
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <Border x:Name="ClockHost"
                            Visibility="{x:Bind ViewModel.ClockVisibility, Mode=OneWay}"
                            Background="Transparent"
                            CornerRadius="6"
                            Padding="8,0"
                            VerticalAlignment="Stretch"
                            PointerEntered="Host_PointerEntered"
                            PointerExited="Host_PointerExited"
                            PointerPressed="Host_PointerPressed"
                            PointerReleased="Host_PointerReleased"
                            Tapped="ClockHost_Tapped">
                        <ToolTipService.ToolTip>
                            <ToolTip Content="{x:Bind ViewModel.ClockTooltip, Mode=OneWay}" />
                        </ToolTipService.ToolTip>
                        <TextBlock Text="{x:Bind ViewModel.ClockText, Mode=OneWay}"
                                   FontSize="{x:Bind ViewModel.TextFontSize, Mode=OneWay}"
                                   Foreground="White"
                                   VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>
        <Border VerticalAlignment="Bottom" Height="1" Background="#18FFFFFF" />
    </Grid>
</Window>
