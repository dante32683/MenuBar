<Window
    x:Class="MenuBar.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:media="using:Microsoft.UI.Xaml.Media"
    mc:Ignorable="d"
    Title="MenuBar">

    <!-- Dark theme keeps flyouts and text consistent with the bar styling. -->
    <Grid x:Name="RootGrid" Background="Transparent" RequestedTheme="Dark" PointerWheelChanged="RootGrid_PointerWheelChanged">
        <Grid.Resources>
            <Style x:Key="BarTextBlockStyle" TargetType="TextBlock">
                <!-- Set this per TextBlock; applying FontFamily on container panels breaks the WinUI XAML compiler. -->
                <Setter Property="FontFamily" Value="Segoe UI Variable" />
            </Style>

            <Style x:Key="AppMenuItemBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="CornerRadius" Value="4" />
                <Setter Property="Padding" Value="8,0,8,0" />
                <Setter Property="Margin" Value="0,3,0,0" />
                <Setter Property="VerticalAlignment" Value="Stretch" />
            </Style>

            <Style x:Key="AppMenuItemHostStyle" TargetType="Grid">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Margin" Value="0,-3,0,0" />
                <Setter Property="VerticalAlignment" Value="Stretch" />
            </Style>

            <Style x:Key="AppMenuItemTextStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <Style x:Key="AppMenuItemTextDisabledStyle"
                   TargetType="TextBlock"
                   BasedOn="{StaticResource AppMenuItemTextStyle}">
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorDisabledBrush}" />
            </Style>

            <LinearGradientBrush x:Key="MediaArtFallbackBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#2AFFFFFF" Offset="0" />
                <GradientStop Color="#14FFFFFF" Offset="0.45" />
                <GradientStop Color="#1E000000" Offset="1" />
            </LinearGradientBrush>

            <Style x:Key="MediaTransportButtonStyle" TargetType="Button">
                <Setter Property="Width" Value="32" />
                <Setter Property="Height" Value="32" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="CornerRadius" Value="{ThemeResource ControlCornerRadius}" />
            </Style>

            <Style x:Key="MediaProgressThumbStyle" TargetType="Thumb">
                <Setter Property="Background" Value="{ThemeResource TextFillColorPrimaryBrush}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Thumb">
                            <Grid Width="14" Height="14">
                                <Ellipse x:Name="SliderInnerThumb"
                                         Width="8"
                                         Height="8"
                                         Fill="{TemplateBinding Background}"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         RenderTransformOrigin="0.5,0.5">
                                    <Ellipse.RenderTransform>
                                        <CompositeTransform />
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                            </Grid>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="SliderInnerThumb" Storyboard.TargetProperty="Fill">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource TextFillColorPrimaryBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SliderInnerThumb" Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.ScaleX)">
                                                <SplineDoubleKeyFrame KeyTime="{StaticResource ControlFastAnimationDuration}" Value="1" KeySpline="{StaticResource ControlFastOutSlowInKeySpline}" />
                                            </DoubleAnimationUsingKeyFrames>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SliderInnerThumb" Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.ScaleY)">
                                                <SplineDoubleKeyFrame KeyTime="{StaticResource ControlFastAnimationDuration}" Value="1" KeySpline="{StaticResource ControlFastOutSlowInKeySpline}" />
                                            </DoubleAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="SliderInnerThumb" Storyboard.TargetProperty="Fill">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource AccentFillColorDefaultBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SliderInnerThumb" Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.ScaleX)">
                                                <SplineDoubleKeyFrame KeyTime="{StaticResource ControlNormalAnimationDuration}" Value="1.75" KeySpline="{StaticResource ControlFastOutSlowInKeySpline}" />
                                            </DoubleAnimationUsingKeyFrames>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SliderInnerThumb" Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.ScaleY)">
                                                <SplineDoubleKeyFrame KeyTime="{StaticResource ControlNormalAnimationDuration}" Value="1.75" KeySpline="{StaticResource ControlFastOutSlowInKeySpline}" />
                                            </DoubleAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="SliderInnerThumb" Storyboard.TargetProperty="Fill">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource AccentFillColorSecondaryBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SliderInnerThumb" Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.ScaleX)">
                                                <SplineDoubleKeyFrame KeyTime="{StaticResource ControlNormalAnimationDuration}" Value="1.2" KeySpline="{StaticResource ControlFastOutSlowInKeySpline}" />
                                            </DoubleAnimationUsingKeyFrames>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SliderInnerThumb" Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.ScaleY)">
                                                <SplineDoubleKeyFrame KeyTime="{StaticResource ControlNormalAnimationDuration}" Value="1.2" KeySpline="{StaticResource ControlFastOutSlowInKeySpline}" />
                                            </DoubleAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="SliderInnerThumb" Storyboard.TargetProperty="Fill">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource TextFillColorDisabledBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="MediaProgressSliderStyle" TargetType="Slider">
                <Setter Property="Height" Value="18" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Margin" Value="0" />
                <Setter Property="Background" Value="{ThemeResource ControlAltFillColorSecondaryBrush}" />
                <Setter Property="Foreground" Value="{ThemeResource AccentFillColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="CornerRadius" Value="2" />
                <Setter Property="UseSystemFocusVisuals" Value="False" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Slider">
                            <Grid Margin="{TemplateBinding Padding}">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="HorizontalThumb" Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource TextFillColorPrimaryBrush}" />
                                                </ObjectAnimationUsingKeyFrames>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="HorizontalTrackRect" Storyboard.TargetProperty="Fill">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource ControlAltFillColorSecondaryBrush}" />
                                                </ObjectAnimationUsingKeyFrames>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="HorizontalDecreaseRect" Storyboard.TargetProperty="Fill">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource AccentFillColorDefaultBrush}" />
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="PointerOver">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="HorizontalThumb" Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource TextFillColorPrimaryBrush}" />
                                                </ObjectAnimationUsingKeyFrames>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="HorizontalTrackRect" Storyboard.TargetProperty="Fill">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource ControlAltFillColorSecondaryBrush}" />
                                                </ObjectAnimationUsingKeyFrames>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="HorizontalDecreaseRect" Storyboard.TargetProperty="Fill">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource AccentFillColorSecondaryBrush}" />
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="HorizontalThumb" Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource TextFillColorSecondaryBrush}" />
                                                </ObjectAnimationUsingKeyFrames>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="HorizontalTrackRect" Storyboard.TargetProperty="Fill">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource ControlAltFillColorSecondaryBrush}" />
                                                </ObjectAnimationUsingKeyFrames>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="HorizontalDecreaseRect" Storyboard.TargetProperty="Fill">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource AccentFillColorTertiaryBrush}" />
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Disabled" />
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid x:Name="SliderContainer"
                                      Grid.Row="0"
                                      Background="Transparent"
                                      MinHeight="18">
                                    <Grid x:Name="HorizontalTemplate" MinHeight="18">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="7" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="7" />
                                        </Grid.RowDefinitions>

                                        <Rectangle x:Name="HorizontalTrackRect"
                                                   Grid.Row="1"
                                                   Grid.ColumnSpan="3"
                                                   Height="3"
                                                   Fill="{ThemeResource ControlAltFillColorSecondaryBrush}"
                                                   RadiusX="1.5"
                                                   RadiusY="1.5" />
                                        <Rectangle x:Name="HorizontalDecreaseRect"
                                                   Grid.Row="1"
                                                   Height="3"
                                                   Fill="{ThemeResource AccentFillColorDefaultBrush}"
                                                   RadiusX="1.5"
                                                   RadiusY="1.5" />
                                        <Thumb x:Name="HorizontalThumb"
                                               Grid.Row="0"
                                               Grid.RowSpan="3"
                                               Grid.Column="1"
                                               Width="14"
                                               Height="14"
                                               Background="{ThemeResource TextFillColorPrimaryBrush}"
                                               Style="{StaticResource MediaProgressThumbStyle}"
                                               AutomationProperties.AccessibilityView="Raw" />
                                        <Grid x:Name="VerticalTemplate" Visibility="Collapsed" />
                                    </Grid>
                                </Grid>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="MenuFlyoutChromePresenterStyle" TargetType="MenuFlyoutPresenter">
                <Setter Property="Background" Value="{StaticResource FlyoutAcrylicBackground}" />
            </Style>

            <Style x:Key="BaseFlyoutPresenterStyle" TargetType="FlyoutPresenter">
                <Setter Property="Padding" Value="0" />
                <Setter Property="CornerRadius" Value="{ThemeResource OverlayCornerRadius}" />
                <Setter Property="Background" Value="{StaticResource FlyoutAcrylicBackground}" />
            </Style>

            <Style x:Key="MediaFlyoutPresenterStyle"
                   TargetType="FlyoutPresenter"
                   BasedOn="{StaticResource BaseFlyoutPresenterStyle}">
                <Setter Property="MinWidth" Value="264" />
            </Style>

            <Style x:Key="NetworkFlyoutPresenterStyle"
                   TargetType="FlyoutPresenter"
                   BasedOn="{StaticResource BaseFlyoutPresenterStyle}">
                <Setter Property="MinWidth" Value="248" />
            </Style>

            <Style x:Key="BatteryFlyoutPresenterStyle"
                   TargetType="FlyoutPresenter"
                   BasedOn="{StaticResource BaseFlyoutPresenterStyle}">
                <Setter Property="MinWidth" Value="232" />
            </Style>

            <Style x:Key="FlyoutDividerStyle" TargetType="Rectangle">
                <Setter Property="Height" Value="1" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="Fill" Value="{ThemeResource ControlStrokeColorSecondaryBrush}" />
                <Setter Property="Opacity" Value="0.7" />
            </Style>

            <Style x:Key="FlyoutCardBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="CornerRadius" Value="0" />
            </Style>

            <Style x:Key="FlyoutSectionBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="CornerRadius" Value="0" />
            </Style>

            <!-- The brush is only a tint layer; the actual blur comes from Flyout/SystemBackdrop. -->
            <!-- Neutral dark tint matches Windows 11 native flyouts (Quick Settings, Volume, etc.) -->
            <AcrylicBrush x:Key="FlyoutAcrylicBackground"
                          TintColor="#202020"
                          TintOpacity="0.85"
                          TintLuminosityOpacity="0.9"
                          FallbackColor="#2C2C2C" />
        </Grid.Resources>

        <Grid.ContextFlyout>
            <!-- SystemBackdrop only applies here because ShouldConstrainToRootBounds is false. -->
            <MenuFlyout ShouldConstrainToRootBounds="False">
                <MenuFlyout.SystemBackdrop>
                    <media:DesktopAcrylicBackdrop />
                </MenuFlyout.SystemBackdrop>
                <MenuFlyout.MenuFlyoutPresenterStyle>
                    <StaticResource ResourceKey="MenuFlyoutChromePresenterStyle" />
                </MenuFlyout.MenuFlyoutPresenterStyle>
                <MenuFlyoutItem Text="Open settings" Click="OpenSettingsFile_Click" />
                <MenuFlyoutItem Text="Reload settings" Click="ReloadSettings_Click" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="Restart bar" Click="RestartBar_Click" />
                <MenuFlyoutItem Text="Stop bar" Click="StopBar_Click" />
            </MenuFlyout>
        </Grid.ContextFlyout>

        <Border x:Name="BackgroundBorder">
            <Grid x:Name="MainContentGrid" Padding="12,3" VerticalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="0" VerticalAlignment="Stretch">
                    <!-- Outer Grid extends hit-test area to the absolute top of the bar (Fitts's Law). -->
                    <Grid Visibility="{x:Bind ViewModel.LogoVisibility, Mode=OneWay}"
                          Background="Transparent"
                          VerticalAlignment="Stretch"
                          Margin="0,-3,0,0"
                          PointerEntered="Host_PointerEntered"
                          PointerExited="Host_PointerExited"
                          PointerPressed="Host_PointerPressed"
                          PointerReleased="Host_PointerReleased"
                          Tapped="LogoHost_Tapped">
                        <Border x:Name="LogoHost"
                                Background="Transparent"
                                CornerRadius="{x:Bind ViewModel.HostCornerRadius, Mode=OneWay}"
                                Padding="{x:Bind ViewModel.HostPadding, Mode=OneWay}"
                                Margin="0,3,0,0"
                                VerticalAlignment="Stretch">
                            <FlyoutBase.AttachedFlyout>
                                <!-- Same backdrop rule applies to all popups in this file. -->
                                <MenuFlyout ShouldConstrainToRootBounds="False">
                                    <MenuFlyout.SystemBackdrop>
                                        <media:DesktopAcrylicBackdrop />
                                    </MenuFlyout.SystemBackdrop>
                                    <MenuFlyout.MenuFlyoutPresenterStyle>
                                        <StaticResource ResourceKey="MenuFlyoutChromePresenterStyle" />
                                    </MenuFlyout.MenuFlyoutPresenterStyle>
                                    <MenuFlyoutItem Text="Settings" Click="OpenWindowsSettings_Click" />
                                    <MenuFlyoutSeparator />
                                    <MenuFlyoutItem Text="Sleep" Click="SleepSystem_Click" />
                                    <MenuFlyoutItem Text="Restart" Click="RestartSystem_Click" />
                                    <MenuFlyoutSeparator />
                                    <MenuFlyoutItem Text="Shut down" Click="ShutdownSystem_Click" />
                                </MenuFlyout>
                            </FlyoutBase.AttachedFlyout>
                            <Grid Width="{x:Bind ViewModel.IconFontSize, Mode=OneWay}"
                                  Height="{x:Bind ViewModel.IconFontSize, Mode=OneWay}"
                                  VerticalAlignment="Center">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Rectangle Fill="White" Grid.Row="0" Grid.Column="0" Margin="0,0,1,1" />
                                <Rectangle Fill="White" Grid.Row="0" Grid.Column="1" Margin="1,0,0,1" />
                                <Rectangle Fill="White" Grid.Row="1" Grid.Column="0" Margin="0,1,1,0" />
                                <Rectangle Fill="White" Grid.Row="1" Grid.Column="1" Margin="1,1,0,0" />
                            </Grid>
                        </Border>
                    </Grid>

                    <Image Source="{x:Bind ViewModel.ActiveWindowIcon, Mode=OneWay}"
                           Visibility="{x:Bind ViewModel.ActiveWindowIconVisibility, Mode=OneWay}"
                           Width="{x:Bind ViewModel.IconFontSize, Mode=OneWay}"
                           Height="{x:Bind ViewModel.IconFontSize, Mode=OneWay}"
                           Margin="8,0,0,0"
                           VerticalAlignment="Center" />

                    <TextBlock Text="{x:Bind ViewModel.ActiveWindowTitle, Mode=OneWay}"
                               Visibility="{x:Bind ViewModel.TitleVisibility, Mode=OneWay}"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                               FontFamily="Segoe UI Variable, Segoe UI"
                               FontWeight="SemiBold"
                               FontSize="{x:Bind ViewModel.TextFontSize, Mode=OneWay}"
                               MaxWidth="340"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"
                               Margin="4,0,0,0" />

                    <!-- App menu items are added here dynamically by RefreshAppMenu() -->
                    <StackPanel x:Name="AppMenuPanel"
                                Orientation="Horizontal"
                                Spacing="0"
                                VerticalAlignment="Stretch" />
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="2" VerticalAlignment="Stretch">
                    <!-- Outer Grid extends hit-test area to the absolute top of the bar (Fitts's Law). -->
                    <Grid Visibility="{x:Bind ViewModel.MediaVisibility, Mode=OneWay}"
                          Background="Transparent"
                          VerticalAlignment="Stretch"
                          Margin="0,-3,0,0"
                          PointerEntered="Host_PointerEntered"
                          PointerExited="Host_PointerExited"
                          PointerPressed="Host_PointerPressed"
                          PointerReleased="Host_PointerReleased"
                          Tapped="MediaHost_Tapped">
                    <Border x:Name="MediaHost"
                            Background="Transparent"
                            CornerRadius="{x:Bind ViewModel.HostCornerRadius, Mode=OneWay}"
                            Padding="{x:Bind ViewModel.HostPadding, Mode=OneWay}"
                            Margin="0,3,0,0"
                            VerticalAlignment="Stretch">
                        <FlyoutBase.AttachedFlyout>
                            <!-- Same backdrop rule applies to all popups in this file. -->
                            <Flyout Opened="MediaFlyout_Opened"
                                    Closed="MediaFlyout_Closed"
                                    Placement="Bottom"
                                    ShouldConstrainToRootBounds="False">
                                <Flyout.SystemBackdrop>
                                    <media:DesktopAcrylicBackdrop />
                                </Flyout.SystemBackdrop>
                                <Flyout.FlyoutPresenterStyle>
                                    <StaticResource ResourceKey="MediaFlyoutPresenterStyle" />
                                </Flyout.FlyoutPresenterStyle>
                                <Grid Padding="12"
                                      MinWidth="264">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Spacing="10">
                                            <Border Width="{x:Bind ViewModel.MediaAlbumArtSize, Mode=OneWay}"
                                                    Height="{x:Bind ViewModel.MediaAlbumArtSize, Mode=OneWay}"
                                                    CornerRadius="10"
                                                    Background="{ThemeResource ControlAltFillColorQuarternaryBrush}"
                                                    HorizontalAlignment="Center">
                                                <Grid>
                                                    <Rectangle Fill="{StaticResource MediaArtFallbackBrush}" />
                                                    <Image Source="{x:Bind ViewModel.MediaAlbumCover, Mode=OneWay}"
                                                           Stretch="UniformToFill" />
                                                </Grid>
                                            </Border>

                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="6"
                                                        HorizontalAlignment="Center"
                                                        Visibility="{x:Bind ViewModel.MediaInlineSourceVisibility, Mode=OneWay}">
                                                <Image Source="{x:Bind ViewModel.MediaSourceAppIcon, Mode=OneWay}"
                                                       Visibility="{x:Bind ViewModel.MediaSourceAppIconVisibility, Mode=OneWay}"
                                                       Width="14"
                                                       Height="14"
                                                       VerticalAlignment="Center" />
                                                <TextBlock Text="{x:Bind ViewModel.MediaSourceApp, Mode=OneWay}"
                                                           FontFamily="Segoe UI Variable, Segoe UI"
                                                           FontSize="{x:Bind ViewModel.FlyoutCaptionFontSize, Mode=OneWay}"
                                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxWidth="120"
                                                           TextAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                        </StackPanel>

                                        <Grid Grid.Column="1"
                                              Margin="12,0,0,0"
                                              VerticalAlignment="Center">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <Grid>
                                                <StackPanel Spacing="1"
                                                            VerticalAlignment="Center"
                                                            HorizontalAlignment="Center"
                                                            Visibility="{x:Bind ViewModel.MediaInlineTransportVisibility, Mode=OneWay}">
                                                    <TextBlock Text="{x:Bind ViewModel.MediaTitle, Mode=OneWay}"
                                                               FontFamily="Segoe UI Variable, Segoe UI"
                                                               FontWeight="SemiBold"
                                                               FontSize="{x:Bind ViewModel.FlyoutBodyFontSize, Mode=OneWay}"
                                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                               TextTrimming="CharacterEllipsis"
                                                               TextAlignment="Center"
                                                               MaxWidth="172" />
                                                    <TextBlock Text="{x:Bind ViewModel.MediaArtist, Mode=OneWay}"
                                                               FontFamily="Segoe UI Variable, Segoe UI"
                                                               FontSize="{x:Bind ViewModel.FlyoutCaptionFontSize, Mode=OneWay}"
                                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                               TextTrimming="CharacterEllipsis"
                                                               TextAlignment="Center"
                                                               MaxWidth="172" />
                                                </StackPanel>

                                                <StackPanel Spacing="1"
                                                            VerticalAlignment="Center"
                                                            Visibility="{x:Bind ViewModel.MediaStandardTransportVisibility, Mode=OneWay}">
                                                    <TextBlock Text="{x:Bind ViewModel.MediaTitle, Mode=OneWay}"
                                                               FontFamily="Segoe UI Variable, Segoe UI"
                                                               FontWeight="SemiBold"
                                                               FontSize="{x:Bind ViewModel.FlyoutBodyFontSize, Mode=OneWay}"
                                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                               TextTrimming="CharacterEllipsis"
                                                               MaxWidth="172" />
                                                    <TextBlock Text="{x:Bind ViewModel.MediaArtist, Mode=OneWay}"
                                                               FontFamily="Segoe UI Variable, Segoe UI"
                                                               FontSize="{x:Bind ViewModel.FlyoutCaptionFontSize, Mode=OneWay}"
                                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                               TextTrimming="CharacterEllipsis"
                                                               MaxWidth="172" />
                                                    <StackPanel Orientation="Horizontal"
                                                                Spacing="6"
                                                                Margin="0,3,0,0"
                                                                Visibility="{x:Bind ViewModel.MediaStandardSourceVisibility, Mode=OneWay}">
                                                        <Image Source="{x:Bind ViewModel.MediaSourceAppIcon, Mode=OneWay}"
                                                               Visibility="{x:Bind ViewModel.MediaSourceAppIconVisibility, Mode=OneWay}"
                                                               Width="14"
                                                               Height="14"
                                                               VerticalAlignment="Center" />
                                                        <TextBlock Text="{x:Bind ViewModel.MediaSourceApp, Mode=OneWay}"
                                                                   FontFamily="Segoe UI Variable, Segoe UI"
                                                                   FontSize="{x:Bind ViewModel.FlyoutCaptionFontSize, Mode=OneWay}"
                                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   MaxWidth="152" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Grid>

                                            <StackPanel Grid.Row="1"
                                                        Visibility="{x:Bind ViewModel.MediaInlineTransportVisibility, Mode=OneWay}"
                                                        Orientation="Horizontal"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Spacing="8"
                                                        Margin="0,10,0,0">
                                                <Button Click="MediaShuffle_Click"
                                                        Style="{StaticResource MediaTransportButtonStyle}"
                                                        Visibility="{x:Bind ViewModel.MediaShuffleVisibility, Mode=OneWay}"
                                                        Opacity="{x:Bind ViewModel.MediaShuffleOpacity, Mode=OneWay}">
                                                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE8B1;" FontSize="13" />
                                                </Button>
                                                <Button Click="MediaPrevious_Click"
                                                        Style="{StaticResource MediaTransportButtonStyle}">
                                                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE892;" FontSize="16" />
                                                </Button>
                                                <Button Click="MediaPlayPause_Click"
                                                        Style="{StaticResource AccentButtonStyle}"
                                                        Width="40"
                                                        Height="40"
                                                        CornerRadius="10"
                                                        Padding="0">
                                                    <SymbolIcon Symbol="{x:Bind ViewModel.MediaPlayPauseSymbol, Mode=OneWay}" />
                                                </Button>
                                                <Button Click="MediaNext_Click"
                                                        Style="{StaticResource MediaTransportButtonStyle}">
                                                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE893;" FontSize="16" />
                                                </Button>
                                                <Button Click="MediaRepeat_Click"
                                                        Style="{StaticResource MediaTransportButtonStyle}"
                                                        Visibility="{x:Bind ViewModel.MediaRepeatVisibility, Mode=OneWay}"
                                                        Opacity="{x:Bind ViewModel.MediaRepeatOpacity, Mode=OneWay}">
                                                    <FontIcon FontFamily="Segoe Fluent Icons"
                                                              Glyph="{x:Bind ViewModel.MediaRepeatIcon, Mode=OneWay}"
                                                              FontSize="13" />
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>

                                    <StackPanel Grid.Row="1"
                                                Visibility="{x:Bind ViewModel.MediaStandardTransportVisibility, Mode=OneWay}"
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                Spacing="12"
                                                Margin="0,12,0,0">
                                        <Button Click="MediaShuffle_Click"
                                                Style="{StaticResource MediaTransportButtonStyle}"
                                                Visibility="{x:Bind ViewModel.MediaShuffleVisibility, Mode=OneWay}"
                                                Opacity="{x:Bind ViewModel.MediaShuffleOpacity, Mode=OneWay}">
                                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE8B1;" FontSize="13" />
                                        </Button>
                                        <Button Click="MediaPrevious_Click"
                                                Style="{StaticResource MediaTransportButtonStyle}">
                                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE892;" FontSize="16" />
                                        </Button>
                                        <Button Click="MediaPlayPause_Click"
                                                Style="{StaticResource AccentButtonStyle}"
                                                Width="40"
                                                Height="40"
                                                CornerRadius="10"
                                                Padding="0">
                                            <SymbolIcon Symbol="{x:Bind ViewModel.MediaPlayPauseSymbol, Mode=OneWay}" />
                                        </Button>
                                        <Button Click="MediaNext_Click"
                                                Style="{StaticResource MediaTransportButtonStyle}">
                                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE893;" FontSize="16" />
                                        </Button>
                                        <Button Click="MediaRepeat_Click"
                                                Style="{StaticResource MediaTransportButtonStyle}"
                                                Visibility="{x:Bind ViewModel.MediaRepeatVisibility, Mode=OneWay}"
                                                Opacity="{x:Bind ViewModel.MediaRepeatOpacity, Mode=OneWay}">
                                            <FontIcon FontFamily="Segoe Fluent Icons"
                                                      Glyph="{x:Bind ViewModel.MediaRepeatIcon, Mode=OneWay}"
                                                      FontSize="13" />
                                        </Button>
                                    </StackPanel>

                                    <StackPanel Grid.Row="2"
                                                Visibility="{x:Bind ViewModel.MediaFlyoutProgressVisibility, Mode=OneWay}"
                                                Spacing="2"
                                                Margin="0,10,0,0">
                                        <Slider x:Name="MediaProgressSlider"
                                                Minimum="0"
                                                IsThumbToolTipEnabled="False"
                                                Padding="0"
                                                ValueChanged="MediaProgressSlider_ValueChanged"
                                                PointerReleased="MediaProgressSlider_PointerReleased"
                                                PointerPressed="MediaProgressSlider_PointerPressed"
                                                Style="{StaticResource MediaProgressSliderStyle}" />
                                        <Grid>
                                            <TextBlock Text="{x:Bind ViewModel.MediaPositionText, Mode=OneWay}"
                                                       FontSize="{x:Bind ViewModel.FlyoutCaptionFontSize, Mode=OneWay}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       HorizontalAlignment="Left" />
                                            <TextBlock Text="{x:Bind ViewModel.MediaDurationText, Mode=OneWay}"
                                                       FontSize="{x:Bind ViewModel.FlyoutCaptionFontSize, Mode=OneWay}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       HorizontalAlignment="Right" />
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </Flyout>
                        </FlyoutBase.AttachedFlyout>
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <Ellipse Width="6" Height="6" Fill="{x:Bind ViewModel.MediaIndicatorBrush, Mode=OneWay}" />
                            <TextBlock Text="{x:Bind ViewModel.MediaText, Mode=OneWay}"
                                       FontFamily="Segoe UI Variable, Segoe UI"
                                       FontSize="{x:Bind ViewModel.TextFontSize, Mode=OneWay}"
                                       MaxWidth="210"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    </Grid>

                    <!-- Outer Grid extends hit-test area to the absolute top of the bar (Fitts's Law). -->
                    <Grid Visibility="{x:Bind ViewModel.PhoneVisibility, Mode=OneWay}"
                          Background="Transparent"
                          VerticalAlignment="Stretch"
                          Margin="0,-3,0,0"
                          PointerEntered="Host_PointerEntered"
                          PointerExited="Host_PointerExited"
                          PointerPressed="Host_PointerPressed"
                          PointerReleased="Host_PointerReleased"
                          Tapped="PhoneHost_Tapped">
                        <Border x:Name="PhoneHost"
                                Background="Transparent"
                                CornerRadius="{x:Bind ViewModel.HostCornerRadius, Mode=OneWay}"
                                Padding="{x:Bind ViewModel.HostPadding, Mode=OneWay}"
                                Margin="0,3,0,0"
                                VerticalAlignment="Stretch">
                            <FlyoutBase.AttachedFlyout>
                                <MenuFlyout Placement="Bottom" ShouldConstrainToRootBounds="False">
                                    <MenuFlyout.SystemBackdrop>
                                        <media:DesktopAcrylicBackdrop />
                                    </MenuFlyout.SystemBackdrop>
                                    <MenuFlyout.MenuFlyoutPresenterStyle>
                                        <StaticResource ResourceKey="MenuFlyoutChromePresenterStyle" />
                                    </MenuFlyout.MenuFlyoutPresenterStyle>
                                    <MenuFlyoutItem Text="Bring to front" Click="PhoneBringToFront_Click" />
                                    <MenuFlyoutSeparator />
                                    <MenuFlyoutItem Text="Reconnect" Click="PhoneReconnect_Click" />
                                    <MenuFlyoutItem Text="Disconnect" Click="PhoneDisconnect_Click" />
                                </MenuFlyout>
                            </FlyoutBase.AttachedFlyout>
                            <Grid>
                                <TextBlock x:Name="PhoneIcon"
                                           Text="&#xF6C6;"
                                           FontFamily="Segoe Fluent Icons"
                                           FontSize="{x:Bind ViewModel.IconFontSize, Mode=OneWay}"
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center" />
                                <ProgressRing x:Name="PhoneSpinner"
                                              IsActive="True"
                                              Visibility="Collapsed"
                                              Width="{x:Bind ViewModel.IconFontSize, Mode=OneWay}"
                                              Height="{x:Bind ViewModel.IconFontSize, Mode=OneWay}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center" />
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Outer Grid extends hit-test area to the absolute top of the bar (Fitts's Law). -->
                    <Grid Visibility="{x:Bind ViewModel.NetworkVisibility, Mode=OneWay}"
                          Background="Transparent"
                          VerticalAlignment="Stretch"
                          Margin="0,-3,0,0"
                          PointerEntered="Host_PointerEntered"
                          PointerExited="Host_PointerExited"
                          PointerPressed="Host_PointerPressed"
                          PointerReleased="Host_PointerReleased"
                          Tapped="NetworkHost_Tapped">
                    <Border x:Name="NetworkHost"
                            Background="Transparent"
                            CornerRadius="{x:Bind ViewModel.HostCornerRadius, Mode=OneWay}"
                            Padding="{x:Bind ViewModel.HostPadding, Mode=OneWay}"
                            Margin="0,3,0,0"
                            VerticalAlignment="Stretch">
                        <FlyoutBase.AttachedFlyout>
                            <!-- Same backdrop rule applies to all popups in this file. -->
                            <Flyout Placement="Bottom" ShouldConstrainToRootBounds="False">
                                <Flyout.SystemBackdrop>
                                    <media:DesktopAcrylicBackdrop />
                                </Flyout.SystemBackdrop>
                                <Flyout.FlyoutPresenterStyle>
                                    <StaticResource ResourceKey="NetworkFlyoutPresenterStyle" />
                                </Flyout.FlyoutPresenterStyle>
                                <Grid Padding="12" MinWidth="248">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock x:Name="NetworkFlyoutIcon"
                                                   Text="{x:Bind ViewModel.NetworkIcon, Mode=OneWay}"
                                                   FontFamily="Segoe Fluent Icons"
                                                   FontSize="{x:Bind ViewModel.FlyoutIconFontSize, Mode=OneWay}"
                                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,10,0" />

                                        <StackPanel Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    Spacing="3">
                                            <TextBlock x:Name="NetworkFlyoutName"
                                                       Text="Wi-Fi"
                                                       FontFamily="Segoe UI Variable, Segoe UI"
                                                       FontWeight="SemiBold"
                                                       FontSize="{x:Bind ViewModel.FlyoutBodyFontSize, Mode=OneWay}"
                                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxWidth="184" />
                                            <TextBlock x:Name="NetworkFlyoutStatus"
                                                       Text="Connected"
                                                       FontFamily="Segoe UI Variable, Segoe UI"
                                                       FontSize="{x:Bind ViewModel.FlyoutCaptionFontSize, Mode=OneWay}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       TextWrapping="WrapWholeWords"
                                                       MaxWidth="184" />
                                        </StackPanel>
                                    </Grid>

                                    <Rectangle Grid.Row="1"
                                               Style="{StaticResource FlyoutDividerStyle}"
                                               Margin="-12,10,-12,0"
                                               Visibility="{x:Bind NetworkFlyoutSpeed.Visibility, Mode=OneWay}" />

                                    <TextBlock x:Name="NetworkFlyoutSpeed"
                                               Grid.Row="2"
                                               Text=""
                                               FontFamily="Segoe UI Variable, Segoe UI"
                                               FontSize="{x:Bind ViewModel.FlyoutCaptionFontSize, Mode=OneWay}"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                               Visibility="Collapsed"
                                               Margin="0,8,0,0" />
                                </Grid>
                            </Flyout>
                        </FlyoutBase.AttachedFlyout>
                        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind ViewModel.NetworkIcon, Mode=OneWay}"
                                       FontFamily="Segoe Fluent Icons"
                                       FontSize="{x:Bind ViewModel.IconFontSize, Mode=OneWay}"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    </Grid>

                    <!-- Outer Grid extends hit-test area to the absolute top of the bar (Fitts's Law). -->
                    <Grid Visibility="{x:Bind ViewModel.BatteryVisibility, Mode=OneWay}"
                          Background="Transparent"
                          VerticalAlignment="Stretch"
                          Margin="0,-3,0,0"
                          PointerEntered="Host_PointerEntered"
                          PointerExited="Host_PointerExited"
                          PointerPressed="Host_PointerPressed"
                          PointerReleased="Host_PointerReleased"
                          Tapped="BatteryHost_Tapped">
                    <Border x:Name="BatteryHost"
                            Background="Transparent"
                            CornerRadius="{x:Bind ViewModel.HostCornerRadius, Mode=OneWay}"
                            Padding="{x:Bind ViewModel.HostPadding, Mode=OneWay}"
                            Margin="0,3,0,0"
                            VerticalAlignment="Stretch">
                        <FlyoutBase.AttachedFlyout>
                            <!-- Same backdrop rule applies to all popups in this file. -->
                            <Flyout Placement="Bottom" ShouldConstrainToRootBounds="False"
                                    Opened="BatteryFlyout_Opened">
                                <Flyout.SystemBackdrop>
                                    <media:DesktopAcrylicBackdrop />
                                </Flyout.SystemBackdrop>
                                <Flyout.FlyoutPresenterStyle>
                                    <StaticResource ResourceKey="BatteryFlyoutPresenterStyle" />
                                </Flyout.FlyoutPresenterStyle>
                                <Grid x:Name="BatteryFlyoutRoot" Padding="12" MinWidth="232">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Grid VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind ViewModel.BatteryIcon, Mode=OneWay}"
                                                       FontFamily="Segoe Fluent Icons"
                                                       FontSize="{x:Bind ViewModel.FlyoutIconFontSize, Mode=OneWay}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{x:Bind BatteryFillGlyphText.Foreground, Mode=OneWay}" />
                                            <TextBlock Text="{x:Bind BatteryOutlineGlyphText.Text, Mode=OneWay}"
                                                       Visibility="{x:Bind BatteryOutlineGlyphText.Visibility, Mode=OneWay}"
                                                       FontFamily="Segoe Fluent Icons"
                                                       FontSize="{x:Bind ViewModel.FlyoutIconFontSize, Mode=OneWay}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                        </Grid>

                                        <StackPanel Grid.Column="1"
                                                    Margin="10,0,0,0"
                                                    VerticalAlignment="Center"
                                                    Spacing="3">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                                                <TextBlock Text="{x:Bind ViewModel.BatteryFlyoutPercent, Mode=OneWay}"
                                                           FontFamily="Segoe UI Variable, Segoe UI"
                                                           FontSize="{x:Bind ViewModel.FlyoutTitleFontSize, Mode=OneWay}"
                                                           FontWeight="SemiBold"
                                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                                <StackPanel Orientation="Horizontal"
                                                            VerticalAlignment="Bottom"
                                                            Margin="8,0,0,1"
                                                            Visibility="{x:Bind ViewModel.BatteryFlyoutWattageVisibility, Mode=OneWay}">
                                                    <TextBlock Text="{x:Bind ViewModel.BatteryFlyoutWattageIcon, Mode=OneWay}"
                                                               FontFamily="Segoe Fluent Icons"
                                                               FontSize="{x:Bind ViewModel.FlyoutCaptionFontSize, Mode=OneWay}"
                                                               Foreground="{x:Bind ViewModel.BatteryFlyoutWattageBrush, Mode=OneWay}"
                                                               VerticalAlignment="Center" />
                                                    <TextBlock Text="{x:Bind ViewModel.BatteryFlyoutWattage, Mode=OneWay}"
                                                               FontFamily="Segoe UI Variable, Segoe UI"
                                                               FontSize="{x:Bind ViewModel.FlyoutCaptionFontSize, Mode=OneWay}"
                                                               FontWeight="Medium"
                                                               Foreground="{x:Bind ViewModel.BatteryFlyoutWattageBrush, Mode=OneWay}"
                                                               Margin="3,0,0,0"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                            </StackPanel>

                                            <TextBlock Text="{x:Bind ViewModel.BatteryFlyoutStatus, Mode=OneWay}"
                                                       FontFamily="Segoe UI Variable, Segoe UI"
                                                       FontSize="{x:Bind ViewModel.FlyoutCaptionFontSize, Mode=OneWay}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                    </Grid>

                                    <ProgressBar Grid.Row="1"
                                                 Maximum="100"
                                                 Value="{x:Bind ViewModel.BatteryFlyoutProgress, Mode=OneWay}"
                                                 Visibility="{x:Bind ViewModel.BatteryFlyoutProgressVisibility, Mode=OneWay}"
                                                 Margin="0,10,0,0" />

                                    <Rectangle Grid.Row="2"
                                               Style="{StaticResource FlyoutDividerStyle}"
                                               Margin="-12,10,-12,0"
                                               Visibility="{x:Bind ViewModel.BatteryFlyoutDetailsVisibility, Mode=OneWay}" />

                                    <StackPanel Grid.Row="3"
                                                Margin="0,8,0,0"
                                                Spacing="4"
                                                Visibility="{x:Bind ViewModel.BatteryFlyoutDetailsVisibility, Mode=OneWay}">
                                        <TextBlock Text="{x:Bind ViewModel.BatteryFlyoutTime, Mode=OneWay}"
                                                   FontFamily="Segoe UI Variable, Segoe UI"
                                                   FontSize="{x:Bind ViewModel.FlyoutCaptionFontSize, Mode=OneWay}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   Visibility="{x:Bind ViewModel.BatteryFlyoutTimeVisibility, Mode=OneWay}" />

                                        <TextBlock Text="{x:Bind ViewModel.BatteryFlyoutProjected, Mode=OneWay}"
                                                   FontFamily="Segoe UI Variable, Segoe UI"
                                                   FontSize="{x:Bind ViewModel.FlyoutCaptionFontSize, Mode=OneWay}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   Visibility="{x:Bind ViewModel.BatteryFlyoutProjectedVisibility, Mode=OneWay}" />

                                        <TextBlock Text="{x:Bind ViewModel.BatteryFlyoutUsageTime, Mode=OneWay}"
                                                   FontFamily="Segoe UI Variable, Segoe UI"
                                                   FontSize="{x:Bind ViewModel.FlyoutCaptionFontSize, Mode=OneWay}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   Visibility="{x:Bind ViewModel.BatteryFlyoutUsageTimeVisibility, Mode=OneWay}" />
                                    </StackPanel>
                                </Grid>
                            </Flyout>
                        </FlyoutBase.AttachedFlyout>
                        <StackPanel Orientation="Horizontal" Spacing="3" VerticalAlignment="Center">
                            <Grid Width="{x:Bind ViewModel.BatteryIconWidth, Mode=OneWay}" VerticalAlignment="Center">
                                <TextBlock x:Name="BatteryFillGlyphText"
                                           Text="{x:Bind ViewModel.BatteryIcon, Mode=OneWay}"
                                           FontFamily="Segoe Fluent Icons"
                                           FontSize="{x:Bind ViewModel.IconFontSize, Mode=OneWay}"
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center" />
                                <TextBlock x:Name="BatteryOutlineGlyphText"
                                           Text="&#xEBA0;"
                                           FontFamily="Segoe Fluent Icons"
                                           FontSize="{x:Bind ViewModel.IconFontSize, Mode=OneWay}"
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center" />
                            </Grid>
                            <TextBlock Text="{x:Bind ViewModel.BatteryText, Mode=OneWay}"
                                       FontFamily="Segoe UI Variable, Segoe UI"
                                       FontSize="{x:Bind ViewModel.TextFontSize, Mode=OneWay}"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                       Margin="{x:Bind ViewModel.BatteryTextMargin, Mode=OneWay}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    </Grid>

                    <!-- Outer Grid extends hit-test area to the absolute top of the bar (Fitts's Law). -->
                    <Grid Visibility="{x:Bind ViewModel.ClockVisibility, Mode=OneWay}"
                          Background="Transparent"
                          VerticalAlignment="Stretch"
                          Margin="0,-3,0,0"
                          PointerEntered="Host_PointerEntered"
                          PointerExited="Host_PointerExited"
                          PointerPressed="Host_PointerPressed"
                          PointerReleased="Host_PointerReleased"
                          Tapped="ClockHost_Tapped">
                        <Border x:Name="ClockHost"
                                Background="Transparent"
                                CornerRadius="{x:Bind ViewModel.HostCornerRadius, Mode=OneWay}"
                                Padding="{x:Bind ViewModel.HostPadding, Mode=OneWay}"
                                Margin="0,3,0,0"
                                VerticalAlignment="Stretch">
                            <TextBlock Text="{x:Bind ViewModel.ClockText, Mode=OneWay}"
                                       FontFamily="Segoe UI Variable, Segoe UI"
                                       FontSize="{x:Bind ViewModel.TextFontSize, Mode=OneWay}"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                       VerticalAlignment="Center" />
                        </Border>
                    </Grid>
                </StackPanel>

                <!-- Virtual desktop pill — centered over the full bar width -->
                <Border x:Name="VirtualDesktopHost"
                        Grid.Column="0"
                        Grid.ColumnSpan="4"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Visibility="{x:Bind ViewModel.VirtualDesktopVisibility, Mode=OneWay}"
                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                        BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="10,3"
                        PointerEntered="VirtualDesktopHost_PointerEntered"
                        PointerExited="VirtualDesktopHost_PointerExited"
                        PointerPressed="VirtualDesktopHost_PointerPressed"
                        PointerReleased="VirtualDesktopHost_PointerReleased"
                        Tapped="VirtualDesktopHost_Tapped">
                    <TextBlock Text="{x:Bind ViewModel.VirtualDesktopText, Mode=OneWay}"
                               FontFamily="Segoe UI Variable, Segoe UI"
                               FontWeight="SemiBold"
                               FontSize="{x:Bind ViewModel.TextFontSize, Mode=OneWay}"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                               VerticalAlignment="Center" />
                </Border>
            </Grid>
        </Border>
        <!-- Right-edge hit extension for ClockHost. Lives in RootGrid so it doesn't affect column layout. -->
        <Border Visibility="{x:Bind ViewModel.ClockVisibility, Mode=OneWay}"
                HorizontalAlignment="Right"
                VerticalAlignment="Stretch"
                Width="12"
                Background="Transparent"
                PointerEntered="ClockEdge_PointerEntered"
                PointerExited="ClockEdge_PointerExited"
                PointerPressed="ClockEdge_PointerPressed"
                PointerReleased="ClockEdge_PointerReleased"
                Tapped="ClockHost_Tapped" />
        <Border VerticalAlignment="Bottom" Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
    </Grid>
</Window>
